{
    "recall_delay": {
        "description": "自动撤回延迟 (秒)",
        "hint": "发送评分图片后多少秒自动撤回。0 表示不撤回。",
        "type": "int",
        "default": 0
    },
    "show_analyze_alert": {
        "description": "显示分析提示",
        "hint": "是否在开始分析时发送'正在分析...'的提示消息。",
        "type": "bool",
        "default": true
    },
    "output_mode": {
        "description": "输出模式",
        "hint": "评分结果的输出格式。",
        "type": "string",
        "options": ["图片", "文字"],
        "default": "图片"
    },
    "blur_media": {
        "description": "近期媒体打码",
        "hint": "是否对近期媒体图片进行模糊打码处理。",
        "type": "bool",
        "default": false
    }
}
